# Ambil 3 value ini dari Supabase Dashboard > Project Settings > API

# Aman untuk diexpose ke browser (prefix NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RAHASIA — jangan pernah expose ke browser / commit ke git.
# Hanya dipakai di src/lib/supabase/admin.ts (server-only).
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dipakai npm run supabase:types buat generate database.types.ts
SUPABASE_PROJECT_ID=xxxxxxxxxxxx
